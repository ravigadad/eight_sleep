# Home Assistant connection settings
# Copy this file to .env and fill in your values.

# SSH user for rsync/restart
HA_SSH_USER=root

# Home Assistant hostname or IP
HA_HOST=homeassistant.local

# Home Assistant port (default: 8123)
HA_PORT=8123

# Long-lived access token (used by homeassistant deploy.sh for API reloads)
# Generate at: http://<HA_HOST>:<HA_PORT>/profile/security → Long-Lived Access Tokens
HA_TOKEN=your_token_here

# Eight Sleep credentials (used for direct API testing during development)
EIGHT_SLEEP_USERNAME=your_email@example.com
EIGHT_SLEEP_PASSWORD=your_password_here
